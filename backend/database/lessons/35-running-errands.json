    "title": "Running Errands",
    "level": "A2",
    "pattern": {
        "title": "Errands: käydä pankissa, hoitaa",
        "summary": "Quick visits use 'käydä' + -ssa: käydä pankissa (stop by the bank), käydä postissa. 'Hoitaa' is the get-it-done verb: mä hoidan sen = I'll take care of it. Errands are 'jutut' or 'hommat' in speech.",
        "examples": [
            "Mun pitää käydä pankissa. = I have to stop by the bank.",
            "Mä hoidan sen huomenna. = I'll take care of it tomorrow.",
            "Voitsä hakee paketin? = Can you pick up the package?"
        ]
    },
