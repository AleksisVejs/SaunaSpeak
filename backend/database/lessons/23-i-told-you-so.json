{
    "title": "I Told You So",
    "level": "B2",
    "pattern": {
        "title": "The -han flavor: sehän, onhan, mähän",
        "summary": "Stick -han/-hän onto the first word and the sentence gets a knowing tone: 'as we both know', 'oh look', or 'I told you'. Sehän on hieno = well, that IS nice. -pa adds surprise: Onpa kylmä! Small endings, big attitude - Finns use them constantly.",
        "examples": [
            "Sehän on hyvä uutinen! = Well, that's good news!",
            "Mähän sanoin, et näin käy. = I told you this would happen.",
            "Onpa kylmä päivä! = What a cold day!"
        ]
    },
    "sentences": [
        {
            "fi": "Sehän on hyvä uutinen!",
            "en": "Well, that's good news!",
            "written": null,
            "glosses": {
                "sehän": "well, that - 'se' + the knowing -hän",
                "on": "is",
                "hyvä": "good",
                "uutinen": "a piece of news"
            }
        },
        {
            "fi": "Onpa kylmä päivä!",
            "en": "What a cold day!",
            "written": null,
