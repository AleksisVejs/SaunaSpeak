{
    "title": "Buying Clothes",
    "level": "A2",
    "pattern": {
        "title": "Does it fit? sopii, istuu, liian",
        "summary": "Trying clothes on is 'sovittaa': Voinks mä sovittaa tätä? Clothes that fit 'istuu' (sit well) or 'sopii' (suit you). 'Liian' + adjective means too: liian pieni = too small, liian kallis = too expensive.",
        "examples": [
            "Voinks mä sovittaa tätä? = Can I try this on?",
            "Tää on liian pieni. = This is too small.",
            "Toi istuu sulle tosi hyvin. = That fits you really well."
        ]
    },
