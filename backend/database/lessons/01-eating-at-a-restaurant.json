{
    "title": "Eating at a Restaurant",
    "level": "A1",
    "pattern": {
        "title": "Spoken Questions and Pronouns",
        "summary": "In spoken Finnish, questions are often formed by adding -ks instead of -ko (e.g., 'onks' instead of 'onko'). We also use the short forms 'mä' (I) and 'sä' (you).",
        "examples": [
            "Onks tässä vapaata? = Is this seat free?",
            "Saaks täält kahvii? = Can I get coffee here?"
        ]
    },
    "sentences": [
        {
            "fi": "Moi, onks tääl tilaa?",
            "en": "Hi, is there space here?",
            "written": "Moi, onko täällä tilaa?",
            "glosses": {
                "moi": "hi",
                "onks": "is - spoken 'onko': the -ko question ending becomes -ks",
                "tääl": "here - spoken 'täällä', the last syllable drops",
                "tilaa": "space - partitive of 'tila'"
            }
        },
        {
            "fi": "Mä otan kahvin.",
            "en": "I'll take a coffee.",
            "written": "Minä otan kahvin.",
            "glosses": {
                "mä": "I - spoken 'minä'",
                "otan": "I take - from 'ottaa'",
                "kahvin": "a coffee - object form of 'kahvi'"
            }
        },
        {
            "fi": "Mitä sä otat?",
            "en": "What will you take?",
            "written": "Mitä sinä otat?",
            "glosses": {
                "mitä": "what",
                "sä": "you - spoken 'sinä'",
                "otat": "you take - from 'ottaa'"
            }
        },
        {
            "fi": "Saaks täält pitsaa?",
            "en": "Can you get pizza here?",
            "written": "Saako täältä pitsaa?",
            "glosses": {
                "saaks": "can one get - spoken 'saako': -ko becomes -ks",
                "täält": "from here - spoken 'täältä', the final vowel drops",
                "pitsaa": "pizza - partitive of 'pitsa'"
            }
        },
        {
            "fi": "Yks iso limu, kiitos.",
            "en": "One large soda, please.",
            "written": "Yksi iso limonadi, kiitos.",
            "glosses": {
                "yks": "one - spoken 'yksi', the final -i drops",
                "iso": "large",
                "limu": "soda - the casual word for 'limonadi'",
                "kiitos": "thanks"
            }
        },
        {
            "fi": "Se tekee kymmenen euroo.",
            "en": "That makes ten euros.",
            "written": "Se tekee kymmenen euroa.",
            "glosses": {
                "se": "it",
                "tekee": "makes - from 'tehdä'",
                "kymmenen": "ten",
                "euroo": "euros - spoken 'euroa': the -oa ending smooths to -oo"
            }
        },
        {
            "fi": "Mä maksan kortilla.",
            "en": "I'll pay by card.",
            "written": "Minä maksan kortilla.",
            "glosses": {
                "mä": "I - spoken 'minä'",
                "maksan": "I pay - from 'maksaa'",
                "kortilla": "by card - 'kortti' + -lla (with)"
            }
        },
        {
            "fi": "Mennäänks syömään?",
            "en": "Shall we go eat?",
            "written": "Mennäänkö syömään?",
            "glosses": {
                "mennäänks": "shall we go - spoken 'mennäänkö': -kö becomes -ks",
                "syömään": "to eat - from 'syödä'"
            }
        }
    ]
}
