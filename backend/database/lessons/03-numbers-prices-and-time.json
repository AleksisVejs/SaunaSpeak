{
    "title": "Numbers, Prices and Time",
    "level": "A1",
    "pattern": {
        "title": "Spoken numbers: yks, kaks, viis",
        "summary": "Numbers shrink in speech: yksi → yks, kaksi → kaks, viisi → viis, seitsemän → seiska. And watch the clock: 'puol viis' counts TOWARD five, so it means half past FOUR.",
        "examples": [
            "Se maksaa kaks euroo. = It costs two euros.",
            "Kello on puol viis. = It's half past four (4:30!).",
            "Mä herään seiskalta. = I wake up at seven."
        ]
    },
