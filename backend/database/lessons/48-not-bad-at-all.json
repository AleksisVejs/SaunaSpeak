{
    "title": "Not Bad at All",
    "level": "C1",
    "pattern": {
        "title": "Understatement: ei huono, ihan jees",
        "summary": "Finnish praise runs cold on purpose. 'Ei huono' (not bad) is a compliment, 'ihan jees' (quite ok) means genuinely good, 'menettelee' (it'll do) can be high praise, and 'ei valittamista' (no complaints) is close to a rave. Calibrate accordingly - in both directions.",
        "examples": [
            "Ei huono! = Not bad! (= that's impressive)",
            "Tää on ihan jees. = This is pretty good.",
            "Menettelee. = It'll do. (often: it's great)"
        ]
    },
