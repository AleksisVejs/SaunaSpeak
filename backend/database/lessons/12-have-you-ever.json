            "en": "Have you eaten yet?",
            "written": "Oletko sinä jo syönyt?",
            "glosses": {
                "ootsä": "have you - spoken 'oletko sinä'",
                "jo": "yet / already",
                "syöny": "eaten - spoken 'syönyt'"
            }
        },
