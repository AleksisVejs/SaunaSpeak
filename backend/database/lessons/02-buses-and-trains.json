{
    "title": "Buses and Trains",
    "level": "A1",
    "pattern": {
        "title": "Shortened Verbs and -ks Questions",
        "summary": "In spoken Finnish, verbs like 'mennä' and 'tulla' are shortened (mä meen, sä tuut). Questions ending in '-ko' or '-kö' change to '-ks' for a faster flow.",
        "examples": [
            "Mä meen bussilla. = I'm going by bus.",
            "Onks tää juna? = Is this the train?"
        ]
    },
    "sentences": [
        {
            "fi": "Onks tää bussi?",
            "en": "Is this the bus?",
            "written": "Onko tämä bussi?",
            "glosses": {
                "onks": "is - spoken 'onko': the -ko question ending becomes -ks",
                "tää": "this - spoken 'tämä'",
                "bussi": "bus"
            }
        },
        {
            "fi": "Onks toi juna?",
            "en": "Is that the train?",
            "written": "Onko tuo juna?",
            "glosses": {
                "onks": "is - spoken 'onko': -ko becomes -ks",
                "toi": "that - spoken 'tuo'",
                "juna": "train"
            }
        },
        {
            "fi": "Mä meen junalla.",
            "en": "I'm going by train.",
            "written": "Minä menen junalla.",
            "glosses": {
                "mä": "I - spoken 'minä'",
                "meen": "I go - spoken 'menen': the verb squeezes to one syllable",
                "junalla": "by train - 'juna' + -lla (by/with)"
            }
        },
        {
            "fi": "Me mennään nyt.",
            "en": "We are going now.",
            "written": "Me menemme nyt.",
            "glosses": {
                "me": "we",
                "mennään": "go - spoken Finnish swaps 'me menemme' for the let's-form: 'me mennään'",
                "nyt": "now"
            }
        },
        {
            "fi": "Millon se tulee?",
            "en": "When does it come?",
            "written": "Milloin se tulee?",
            "glosses": {
                "millon": "when - spoken 'milloin', the i slips out",
                "se": "it",
                "tulee": "comes - from 'tulla'"
            }
        },
        {
            "fi": "Se tulee viideltä.",
            "en": "It comes at five.",
            "written": null,
            "glosses": {
                "se": "it",
                "tulee": "comes - from 'tulla'",
                "viideltä": "at five - 'viisi' + -ltä"
            }
        },
        {
            "fi": "Tuuks sä mukaan?",
            "en": "Are you coming along?",
            "written": "Tuletko sinä mukaan?",
            "glosses": {
                "tuuks": "are (you) coming - spoken 'tuletko': the verb shortens AND -ko becomes -ks",
                "sä": "you - spoken 'sinä'",
                "mukaan": "along"
            }
        },
        {
            "fi": "Mennään jo!",
            "en": "Let's go already!",
            "written": null,
            "glosses": {
                "mennään": "let's go - the everyday let's-do-it form",
                "jo": "already"
            }
        }
    ]
}
