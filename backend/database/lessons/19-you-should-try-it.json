    "pattern": {
        "title": "Worth doing: kannattaa, sun kannattais",
        "summary": "'Kannattaa' means it's worth it / you should: sun kannattaa kokeilla = you should try. Softer advice takes the conditional: sun kannattais. The negative 'ei kannata' = don't bother. For it-was-worth-it, Helsinki slang has 'sen väärti'.",
        "examples": [
            "Sun kannattaa kokeilla tätä. = You should try this.",
            "Ei kannata ostaa tota. = It's not worth buying that.",
            "Se oli kyl sen väärti. = It was totally worth it."
        ]
    },
