# SaunaSpeak production env - copy to .env on the server and fill in.
APP_NAME=SaunaSpeak
APP_ENV=production
APP_DEBUG=false
APP_KEY=                       # run: php artisan key:generate
APP_URL=https://saunaspeak.com

APP_LOCALE=en
LOG_CHANNEL=daily
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=                   # cPanel → MySQL Databases (name is usually cpuser_saunaspeak)
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# --- AI: Sauna Chat + corrections ---
# Preferred: OpenRouter (prepaid credits, no free-tier quota walls) - openrouter.ai → Keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash              # Väinö's voice (register bake-off winner)
OPENROUTER_MODEL_CORRECT=deepseek/deepseek-v4-flash   # corrections (error-detection winner, ~15x cheaper)
# Fallback: Gemini free tier (low daily/minute quotas) - aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Chat voice fallback for shared hosting (edge-tts won't run on cPanel) ---
# console.cloud.google.com → enable "Cloud Text-to-Speech API" → API key
GOOGLE_TTS_API_KEY=

# --- Löyly+ billing: leave ALL THREE empty until launch (everything stays free) ---
STRIPE_SECRET=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Mail (verification emails + review reminders) ---
# cPanel: Email Accounts -> create noreply@saunaspeak.com, then use its SMTP.
# Without this block MAIL_MAILER defaults to "log": mails only appear in
# storage/logs and nothing is actually sent.
MAIL_MAILER=smtp
MAIL_HOST=mail.saunaspeak.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=noreply@saunaspeak.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@saunaspeak.com
MAIL_FROM_NAME=SaunaSpeak
