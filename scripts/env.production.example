# SaunaSpeak production env — copy to .env on the server and fill in.
APP_NAME=SaunaSpeak
APP_ENV=production
APP_DEBUG=false
APP_KEY=                       # run: php artisan key:generate
APP_URL=https://YOURDOMAIN.com

APP_LOCALE=en
LOG_CHANNEL=daily
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=                   # cPanel → MySQL Databases (name is usually cpuser_saunaspeak)
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# --- AI: Sauna Chat + corrections (free tier: aistudio.google.com/apikey) ---
GEMINI_API_KEY=

# --- Chat voice fallback for shared hosting (edge-tts won't run on cPanel) ---
# console.cloud.google.com → enable "Cloud Text-to-Speech API" → API key
GOOGLE_TTS_API_KEY=

# --- Löyly+ billing: leave ALL THREE empty until launch (everything stays free) ---
STRIPE_SECRET=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
