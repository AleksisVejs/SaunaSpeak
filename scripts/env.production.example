# SaunaSpeak production env - copy to .env on the server and fill in.
APP_NAME=SaunaSpeak
APP_ENV=production
APP_DEBUG=false
APP_KEY=                       # run: php artisan key:generate
APP_URL=https://saunaspeak.com

APP_LOCALE=en
LOG_CHANNEL=daily
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=                   # cPanel → MySQL Databases (name is usually cpuser_saunaspeak)
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# --- AI: Sauna Chat + corrections ---
# Preferred: OpenRouter (prepaid credits, no free-tier quota walls) - openrouter.ai → Keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash              # Väinö's voice (register bake-off winner)
OPENROUTER_MODEL_CORRECT=deepseek/deepseek-v4-flash   # corrections (error-detection winner, ~15x cheaper)
# Fallback: Gemini free tier (low daily/minute quotas) - aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Chat voice fallback for shared hosting (edge-tts won't run on cPanel) ---
# console.cloud.google.com → enable "Cloud Text-to-Speech API" → API key
GOOGLE_TTS_API_KEY=

# --- ElevenLabs: the premium voice tier (optional, mixes with edge-tts) ---
# Only needed on the machine that RUNS `php artisan audio:eleven` - the clips
# ship in git, so the server never calls this API for lesson audio.
# Pick voices that genuinely sound Finnish (Voice Library → filter Finnish):
# edge-tts's fi-FI-HarriNeural is already a native Finnish voice, so a generic
# English-accented voice reading Finnish would be a DOWNGRADE.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_MALE=
ELEVENLABS_VOICE_FEMALE=
ELEVENLABS_MODEL=eleven_multilingual_v2
# Chat replies are unbounded spend (one call per message). Leave false unless
# the character budget is genuinely spare.
ELEVENLABS_FOR_CHAT=false

# --- Löyly+ billing: leave ALL THREE empty until launch (everything stays free) ---
STRIPE_SECRET=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Mail (verification emails + review reminders) ---
# cPanel: Email Accounts -> create mail@saunaspeak.com, then Connect Devices
# to read off the SMTP settings. Without this block MAIL_MAILER defaults to
# "log": mails only appear in storage/logs and nothing is actually sent.
#
# MAIL_HOST is the SERVER's own hostname, not mail.<domain>. Both usually
# work, but they fail differently: mail.saunaspeak.com is a DNS record you
# maintain, and in 2026-07 it pointed at 95.211.208.24 while the server was
# at .241 - one missing digit that silently broke every inbound message to
# the domain for as long as it stood. The server hostname is managed by the
# host and can't drift like that. Whatever you use here must also be covered
# by the domain's SPF record (currently ip4:95.211.208.241), or mail sends
# but lands in spam.
MAIL_MAILER=smtp
MAIL_HOST=server50.areait.lv
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=mail@saunaspeak.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=mail@saunaspeak.com
MAIL_FROM_NAME=SaunaSpeak
